#!/usr/bin/env bash
# ── ContextMesh — Set Fly.io Secrets ─────────────────────────────────────────
# Fill in your values below, then run:  bash set_secrets.sh
# Never commit this file with real values — it is git-ignored.
# ─────────────────────────────────────────────────────────────────────────────

set -euo pipefail
APP="contextmesh-api"

fly secrets set \
  CONTEXTMESH_SECRET="PASTE_RANDOM_64_CHAR_STRING_HERE" \
  OPENAI_API_KEY="sk-proj-..." \
  QDRANT_URL="https://YOUR_CLUSTER.cloud.qdrant.io" \
  QDRANT_API_KEY="YOUR_QDRANT_API_KEY" \
  REDIS_URL="rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379" \
  RESEND_API_KEY="re_..." \
  PADDLE_API_KEY="pdl_live_apikey_..." \
  PADDLE_WEBHOOK_SECRET="pdl_ntfset_..." \
  PADDLE_PRICE_SOLO="pri_..." \
  PADDLE_PRICE_TEAM="pri_..." \
  PADDLE_PRICE_ENTERPRISE="pri_..." \
  --app "$APP"

echo "✅ Secrets set on $APP"
