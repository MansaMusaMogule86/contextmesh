# ── ContextMesh — Environment Variables ───────────────────────────────────────
# Copy to .env and fill in all values before deploying.
# Set on Fly.io with: fly secrets set KEY=value

# ── QDRANT ✓ (already have this) ─────────────────────────────────────────────
QDRANT_URL=https://7314087f-d084-4b18-a243-8a44b2c0ee48.europe-west3-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ── OPENAI ✗ (needed for embeddings — the core feature) ──────────────────────
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── REDIS / UPSTASH ✗ (needed for auth + rate limiting) ──────────────────────
# Get at: https://console.upstash.com → Create DB → copy "Redis URL"
REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ── RESEND ✗ (needed to email API keys to customers) ─────────────────────────
# Get at: https://resend.com → API Keys → Create
RESEND_API_KEY=re_xxx

# ── STRIPE ✗ (needed to take money) ──────────────────────────────────────────
# Secret key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxx
# Webhook secret: https://dashboard.stripe.com/webhooks → Add endpoint
# Endpoint URL: https://api.contextmesh.dev/billing/webhook
# Events to select: checkout.session.completed, customer.subscription.deleted,
#                   invoice.payment_failed, customer.subscription.updated
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs: create 3 products at https://dashboard.stripe.com/products
STRIPE_PRICE_SOLO=price_xxx        # $19/mo recurring
STRIPE_PRICE_TEAM=price_xxx        # $99/mo recurring
STRIPE_PRICE_ENTERPRISE=price_xxx  # $599/mo recurring

# ── APP CONFIG ────────────────────────────────────────────────────────────────
APP_URL=https://contextmesh.dev
API_URL=https://api.contextmesh.dev
CONTEXTMESH_ENV=production
# Generate with: openssl rand -hex 32
CONTEXTMESH_SECRET=generate_random_64_char_string
PORT=8080
WORKERS=2
FROM_EMAIL=keys@contextmesh.dev
